rules_version = '2';

// Deploy with: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    // Path convention: {uid}/{prefix}-{timestamp}.{ext}
    // Avatars/clinic photos/event posters are meant to be public, so anyone
    // can view those. Resumes are different — they're personal documents
    // (phone number, address), so those require being logged in at minimum,
    // rather than being readable by anyone who happens to get the link.
    match /{userId}/{fileName} {
      allow read: if fileName.matches('resume-.*') ? request.auth != null : true;
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 5 * 1024 * 1024
                    && (
                      request.resource.contentType.matches('image/.*') ||
                      request.resource.contentType == 'application/pdf' ||
                      request.resource.contentType == 'application/msword' ||
                      request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                    );
    }
  }
}
