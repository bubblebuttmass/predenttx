rules_version = '2';

// Deploy with: firebase deploy --only storage
service firebase.storage {
  match /b/{bucket}/o {
    // Path convention: {uid}/{prefix}-{timestamp}.{ext}
    // Anyone can view (avatars/clinic photos/event posters are public),
    // but only the owner of that uid folder can write into it, and only
    // images under 5MB.
    match /{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }
  }
}
